# ════════════════════════════════════════════════════════════════
# Tomorrow's People — Environment Variables
# Copy this file to .env and fill in every value before running.
# Never commit .env to version control.
# ════════════════════════════════════════════════════════════════


# ── Database ──────────────────────────────────────────────────────
#
# PostgreSQL connection string.
# Supabase:  Settings → Database → Connection string → URI mode
# Railway:   Dashboard → your DB → Connect tab
# Neon:      Dashboard → Connection Details → Connection string
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tomorrows_people?schema=public&sslmode=require"

# Only needed with Prisma Accelerate (connection pooling for serverless).
# Leave commented out if connecting directly.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/tomorrows_people?schema=public&sslmode=require"


# ── NextAuth ──────────────────────────────────────────────────────
#
# Secret used to sign sessions and tokens.
# Generate with: npx auth secret
# Must be at least 32 characters.
#
AUTH_SECRET="replace-with-output-of-npx-auth-secret"

# Your application's public URL.
# Required in production — NextAuth uses this for OAuth redirects.
# In development, NextAuth infers http://localhost:3000.
# NEXTAUTH_URL="https://your-domain.com"


# ── Google OAuth ──────────────────────────────────────────────────
#
# Create credentials at:
#   console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client
#
# Authorized redirect URIs to add in GCP:
#   Development:  http://localhost:3000/api/auth/callback/google
#   Production:   https://your-domain.com/api/auth/callback/google
#
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"





# ── Cron job security ─────────────────────────────────────────────
#
# Random secret included in the Authorization header by Vercel Cron.
# Prevents anyone from triggering cron routes externally.
# Generate with: openssl rand -hex 32
#
CRON_SECRET="replace-with-at-least-32-char-random-hex"


# ── Runtime (do not change) ───────────────────────────────────────
NODE_ENV="development"
# NODE_ENV="production"   ← set automatically by Vercel / Railway
