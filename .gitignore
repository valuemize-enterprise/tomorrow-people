# ── Dependencies ─────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Next.js ───────────────────────────────────────────────────────
.next/
out/
build/

# ── Prisma ────────────────────────────────────────────────────────
# Keep schema.prisma and migrations tracked.
# Ignore generated client — regenerated on postinstall.
prisma/generated/
prisma/*.db
prisma/*.db-journal

# ── Environment ───────────────────────────────────────────────────
# NEVER commit .env — it contains secrets.
.env
.env.local
.env.*.local

# .env.example IS committed — it documents required variables.
# !.env.example   ← no need to explicitly unignore, it's not in .env patterns

# ── OS / Editor ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/settings.json
*.swp
*.swo

# ── Testing ───────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Vercel ────────────────────────────────────────────────────────
.vercel/

# ── Logs ─────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── TypeScript ────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts
